#!/usr/bin/env bash
set -euo pipefail

BASE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$BASE"

if [ -t 1 ]; then
  C_RESET=$'\u001B[0m'; C_RED=$'\u001B[31m'; C_GREEN=$'\u001B[32m'; C_YELLOW=$'\u001B[33m'; C_MAGENTA=$'\u001B[35m'; C_CYAN=$'\u001B[36m'; C_BOLD=$'\u001B[1m'
else
  C_RESET=''; C_RED=''; C_GREEN=''; C_YELLOW=''; C_MAGENTA=''; C_CYAN=''; C_BOLD=''
fi

say() { printf '%b
' "$*"; }
speak() { if command -v termux-tts-speak >/dev/null 2>&1; then termux-tts-speak "$*" >/dev/null 2>&1 || true; fi }
trim() { local x="$*"; x="${x#${x%%[![:space:]]*}}"; x="${x%${x##*[![:space:]]}}"; printf '%s' "$x"; }

selection=""
resolve_mode_pick() {
  case "$(trim "${1:-}")" in
    1|single|single_shot|market|m) selection="single_shot"; return 0 ;;
    2|ladder|limit|limit_ladder|l) selection="limit_ladder"; return 0 ;;
    *) return 1 ;;
  esac
}

choose_mode() {
  say "1) single shot"
  say "2) limit ladder"
  speak "Set single shot or limit ladder."
  while true; do
    printf 'Set single shot or limit ladder for this deploy? [1/2]: '
    IFS= read -r pick || true
    if resolve_mode_pick "$pick"; then return 0; fi
    say "${C_RED}Say or type: single shot, limit ladder, 1, or 2.${C_RESET}"
  done
}

usdt=""; asset=""; mode=""; lev=""; menu_pick=""; live_flag=""

for tok in "$@"; do
  ltok="${tok,,}"
  if [ "$ltok" = "live" ]; then live_flag="live"; continue; fi
  if [[ "$ltok" =~ ^([0-9]+([.][0-9]+)?)x$ ]]; then lev="$ltok"; continue; fi
  case "$ltok" in
    f|futures|future|ft) mode="futures"; continue ;;
    spot) mode="spot"; continue ;;
    xlm|xrp|btc|eth|sol|doge|ada|hbar|flr) asset="$ltok"; continue ;;
    1|2|single|single_shot|market|m|ladder|limit|limit_ladder|l) continue ;;
  esac
  if [[ "$ltok" =~ ^[0-9]+([.][0-9]+)?$ ]]; then usdt="$ltok"; continue; fi
done

if [ -z "$usdt" ] || [ -z "$asset" ] || [ -z "$mode" ] || [ -z "$lev" ]; then
  say "${C_RED}Usage: deploy <usdt> <asset> <mode> <leverage> [1|2] [live]${C_RESET}"
  exit 1
fi

asset_up="${asset^^}"
voice_line="Set single shot or limit ladder for ${usdt} ${asset_up} ${mode} ${lev}"
say "${C_GREEN}${C_BOLD}deploy_ready:${C_RESET} ${voice_line}"
speak "$voice_line"

if ! resolve_mode_pick "${5:-}"; then choose_mode; fi

say "mode_selected=${selection}"

if [ "$selection" = "single_shot" ]; then
  say "single_shot_payload=set single shot for ${usdt} ${asset_up} ${mode} ${lev}"
  speak "set single shot for ${usdt} ${asset_up} ${mode} ${lev}"
  "$BASE/tools/uvdm_live.py" "$usdt" "$asset_up" "$mode" "$lev" "single" $live_flag
else
  say "limit_ladder_payload=set limit ladder for ${usdt} ${asset_up} ${mode} ${lev}"
  speak "set limit ladder for ${usdt} ${asset_up} ${mode} ${lev}"
  "$BASE/tools/uvdm_live.py" "$usdt" "$asset_up" "$mode" "$lev" "ladder" $live_flag
fi
