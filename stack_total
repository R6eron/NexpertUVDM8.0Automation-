#!/usr/bin/env bash
set -euo pipefail

db="${UVDM_STATE_DB:-$HOME/.config/uvdm/state.db}"

get_value() {
  local key="$1"
  if [[ ! -f "$db" ]]; then
    echo 0
    return
  fi
  grep "^${key}=" "$db" | cut -d'=' -f2 || true
}

xlm_spot="$(get_value XLM_SPOT)"
xlm_fut="$(get_value XLM_FUT)"
flr="$(get_value FLR_TOTAL)"
sgb="$(get_value SGB_TOTAL)"
xrpn="$(get_value XRPN_TOTAL)"

: "${xlm_spot:=0}"
: "${xlm_fut:=0}"
: "${flr:=0}"
: "${sgb:=0}"
: "${xrpn:=0}"

xlm_total=$((xlm_spot + xlm_fut))

echo "XLM:  $xlm_total"
echo "    spot  $xlm_spot"
echo "    fut   $xlm_fut"
echo "FLR:  $flr"
echo "SGB:  $sgb"
echo "XRPN: $xrpn"